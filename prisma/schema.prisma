generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model users {
  id       Int    @id @default(autoincrement())
  username String @db.VarChar(255)
  password String @db.VarChar(255)
  role     Int
  roles    roles  @relation(fields: [role], references: [id], onDelete: SetNull, onUpdate: SetNull, map: "role_fk")
}

model payment {
  id          Int     @id @default(autoincrement())
  description String? @db.VarChar(255)
  status      Int?
}

model roles {
  id     Int     @id @default(autoincrement())
  role   String? @db.VarChar(255)
  status Int?
  users  users[]
}

model course {
  id           Int     @id @default(autoincrement())
  code         String  @unique @db.VarChar(50)
  name         String  @db.VarChar(150)
  description  String?
  units        Int
  status       Int?    @default(1)
  instructor   String? @db.VarChar(50)
  semester     String? @db.VarChar(50)
  max_capacity Int?
  department   Int?
}

model students {
  student_id              Int       @id @default(autoincrement())
  student_number          String    @unique @db.VarChar(20)
  first_name              String    @db.VarChar(100)
  middle_name             String?   @db.VarChar(100)
  last_name               String    @db.VarChar(100)
  suffix                  String?   @db.VarChar(10)
  gender                  String?   @db.VarChar(10)
  date_of_birth           DateTime? @db.Date
  place_of_birth          String?   @db.VarChar(150)
  nationality             String?   @db.VarChar(100)
  civil_status            String?   @db.VarChar(20)
  email_address           String?   @unique @db.VarChar(150)
  contact_number          String?   @db.VarChar(20)
  street                  String?   @db.VarChar(150)
  barangay                String?   @db.VarChar(100)
  city                    String?   @db.VarChar(100)
  province                String?   @db.VarChar(100)
  postal_code             String?   @db.VarChar(10)
  father_name             String?   @db.VarChar(150)
  mother_name             String?   @db.VarChar(150)
  guardian_name           String?   @db.VarChar(150)
  guardian_contact_number String?   @db.VarChar(20)
  guardian_address        String?   @db.VarChar(255)
  course_id               Int?
  year_level              String?   @db.VarChar(50)
  section_id              Int?
  enrollment_id           String?   @default("pending") @db.VarChar
  academic_year           String?   @db.VarChar(20)
}

model enrollment {
  id                       Int       @id @default(autoincrement())
  admission_date           DateTime? @db.Date
  admission_status         String?   @db.VarChar(50)
  term                     String?   @db.VarChar(50)
  department               Int?
  course_program           String?   @db.VarChar(100)
  photo                    String?
  requirements             String[]
  family_name              String?   @db.VarChar(100)
  first_name               String?   @db.VarChar(100)
  middle_name              String?   @db.VarChar(100)
  sex                      String?   @db.VarChar(10)
  civil_status             String?   @db.VarChar(20)
  birthdate                DateTime? @db.Date
  birthplace               String?   @db.VarChar(150)
  complete_address         String?
  contact_number           String?   @db.VarChar(30)
  email_address            String?   @db.VarChar(100)
  emergency_contact_name   String?   @db.VarChar(100)
  emergency_relationship   String?   @db.VarChar(50)
  emergency_contact_number String?   @db.VarChar(30)
  last_school_attended     String?   @db.VarChar(150)
  previous_school_year     String?   @db.VarChar(20)
  program_shs              String?   @db.VarChar(150)
  remarks                  String?
  status                   Int?
  student_number           String?   @db.VarChar(20)
  academic_year            String?   @db.VarChar(20)
  major_id                 Int?
  year_level               Int?      @default(1)
  academic_status          String?   @default("regular") @db.VarChar(50)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model building {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  code        String  @db.VarChar(100)
  description String?
  address     String?
  floor_count Int
  status      String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model department {
  id          Int     @id @default(autoincrement())
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(255)
  description String?
  building_id Int?
  head        String? @db.VarChar(255)
  status      String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model fee {
  id            Int     @id @default(autoincrement())
  code          String  @db.VarChar(50)
  name          String  @db.VarChar(255)
  description   String?
  amount        Decimal @db.Decimal(10, 2)
  category      String  @db.VarChar(20)
  academic_year String  @db.VarChar(20)
  semester      String? @db.VarChar(20)
  status        String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model room {
  id          Int    @id @default(autoincrement())
  building_id Int
  room_number String @db.VarChar(100)
  capacity    Int
  room_type   String @db.VarChar(20)
  floor       Int
  status      String @db.VarChar(20)
}

