generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model users {
  id       Int    @id @default(autoincrement())
  username String @db.VarChar(255)
  password String @db.VarChar(255)
  role     Int
  roles    roles  @relation(fields: [role], references: [id], onDelete: SetNull, onUpdate: SetNull, map: "role_fk")
}

model payment {
  id          Int     @id @default(autoincrement())
  description String? @db.VarChar(255)
  status      Int?
}

model roles {
  id     Int     @id @default(autoincrement())
  role   String? @db.VarChar(255)
  status Int?
  users  users[]
}

model course {
  id           Int     @id @default(autoincrement())
  code         String  @unique @db.VarChar(50)
  name         String  @db.VarChar(150)
  description  String?
  units        Int
  status       Int?    @default(1)
  instructor   String? @db.VarChar(50)
  semester     String? @db.VarChar(50)
  max_capacity Int?
  department   Int?
}

model students {
  student_id              Int       @id @default(autoincrement())
  student_number          String    @unique @db.VarChar(20)
  first_name              String    @db.VarChar(100)
  middle_name             String?   @db.VarChar(100)
  last_name               String    @db.VarChar(100)
  suffix                  String?   @db.VarChar(10)
  gender                  String?   @db.VarChar(10)
  date_of_birth           DateTime? @db.Date
  place_of_birth          String?   @db.VarChar(150)
  nationality             String?   @db.VarChar(100)
  civil_status            String?   @db.VarChar(20)
  email_address           String?   @unique @db.VarChar(150)
  contact_number          String?   @db.VarChar(20)
  street                  String?   @db.VarChar(150)
  barangay                String?   @db.VarChar(100)
  city                    String?   @db.VarChar(100)
  province                String?   @db.VarChar(100)
  postal_code             String?   @db.VarChar(10)
  father_name             String?   @db.VarChar(150)
  mother_name             String?   @db.VarChar(150)
  guardian_name           String?   @db.VarChar(150)
  guardian_contact_number String?   @db.VarChar(20)
  guardian_address        String?   @db.VarChar(255)
  course_id               Int?
  year_level              String?   @db.VarChar(50)
  section_id              Int?
  enrollment_id           String?   @default("pending") @db.VarChar
  academic_year           String?   @db.VarChar(20)
}

model enrollment {
  id                       Int       @id @default(autoincrement())
  admission_date           DateTime? @db.Date
  admission_status         String?   @db.VarChar(50)
  term                     String?   @db.VarChar(50)
  department               Int?
  course_program           String?   @db.VarChar(100)
  photo                    String?   @db.VarChar(255)
  requirements             String[]
  family_name              String?   @db.VarChar(100)
  first_name               String?   @db.VarChar(100)
  middle_name              String?   @db.VarChar(100)
  sex                      String?   @db.VarChar(10)
  civil_status             String?   @db.VarChar(20)
  birthdate                DateTime? @db.Date
  birthplace               String?   @db.VarChar(150)
  complete_address         String?
  contact_number           String?   @db.VarChar(30)
  email_address            String?   @db.VarChar(100)
  emergency_contact_name   String?   @db.VarChar(100)
  emergency_relationship   String?   @db.VarChar(50)
  emergency_contact_number String?   @db.VarChar(30)
  last_school_attended     String?   @db.VarChar(150)
  previous_school_year     String?   @db.VarChar(20)
  program_shs              String?   @db.VarChar(150)
  remarks                  String?
  status                   Int?
  student_number           String?   @db.VarChar(20)
  academic_year            String?   @db.VarChar(20)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model building {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  code        String  @db.VarChar(100)
  description String?
  address     String?
  floor_count Int
  status      String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model department {
  id          Int     @id @default(autoincrement())
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(255)
  description String?
  building_id Int?
  head        String? @db.VarChar(255)
  status      String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model fee {
  id            Int     @id @default(autoincrement())
  code          String  @db.VarChar(50)
  name          String  @db.VarChar(255)
  description   String?
  amount        Decimal @db.Decimal(10, 2)
  category      String  @db.VarChar(20)
  academic_year String  @db.VarChar(20)
  semester      String? @db.VarChar(20)
  status        String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model room {
  id          Int    @id @default(autoincrement())
  building_id Int
  room_number String @db.VarChar(100)
  capacity    Int
  room_type   String @db.VarChar(20)
  floor       Int
  status      String @db.VarChar(20)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model faculty {
  id             Int     @id @default(autoincrement())
  employee_id    String  @db.VarChar(100)
  first_name     String  @db.VarChar(100)
  last_name      String  @db.VarChar(100)
  middle_name    String? @db.VarChar(100)
  email          String  @unique @db.VarChar(150)
  phone          String? @db.VarChar(20)
  department_id  Int
  position       String  @db.VarChar(50)
  specialization String? @db.VarChar(255)
  status         String  @db.VarChar(20)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model major {
  id           Int     @id @default(autoincrement())
  code         String  @db.VarChar(50)
  name         String  @db.VarChar(255)
  description  String?
  program_id   Int
  program_name String? @db.VarChar(255)
  status       String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model program {
  id              Int     @id @default(autoincrement())
  code            String  @db.VarChar(50)
  name            String  @db.VarChar(255)
  description     String?
  department_id   Int?
  department_name String? @db.VarChar(255)
  duration        Int?
  total_units     Int?
  status          String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subject {
  id          Int     @id @default(autoincrement())
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(255)
  description String?
  status      String  @db.VarChar(10)
  units_lec   Int?
  units_lab   Int?
}

model sections {
  id            Int    @id @default(autoincrement())
  program_id    Int
  section_name  String @db.VarChar(100)
  advisor       String @db.VarChar(150)
  student_count Int?   @default(0)
  status        String @db.VarChar(50)
}

model billing {
  id          Int       @id @default(autoincrement())
  enrollee_id Int?
  term        String?   @db.VarChar(10)
  is_paid     Int?
  date_paid   DateTime? @db.Date
  user_id     Int?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model curriculum {
  id                Int                 @id @default(autoincrement())
  program_name      String              @db.VarChar(255)
  program_code      String              @db.VarChar(100)
  major             String?             @db.VarChar(255)
  effective_year    String              @db.VarChar(20)
  total_units       Int
  status            String              @db.VarChar(10)
  curriculum_course curriculum_course[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model curriculum_course {
  id                Int        @id @default(autoincrement())
  curriculum_id     Int
  subject_id        Int?
  course_code       String     @db.VarChar(100)
  descriptive_title String
  units_lec         Int?
  units_lab         Int?
  units_total       Int
  prerequisite      String?
  year_level        Int
  semester          Int
  curriculum        curriculum @relation(fields: [curriculum_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model reports {
  id         Int       @id @default(autoincrement())
  action     String    @db.VarChar(255)
  user_id    Int
  created_at DateTime? @db.Timestamp(6)
}
