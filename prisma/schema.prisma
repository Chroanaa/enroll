/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model major {
  id           Int     @id @default(autoincrement())
  code         String  @db.VarChar(50)
  name         String  @db.VarChar(255)
  description  String?
  program_id   Int
  program_name String? @db.VarChar(255)
  status       String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model program {
  id              Int     @id @default(autoincrement())
  code            String  @db.VarChar(50)
  name            String  @db.VarChar(255)
  description     String?
  department_id   Int?
  department_name String? @db.VarChar(255)
  duration        Int?
  total_units     Int?
  status          String  @db.VarChar(10)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model subject {
  id           Int      @id @default(autoincrement())
  code         String   @db.VarChar(50)
  name         String   @db.VarChar(255)
  description  String?
  status       String   @db.VarChar(10)
  units_lec    Int?
  units_lab    Int?
  lecture_hour Int?
  lab_hour     Int?
  fixedAmount  Decimal? @db.Decimal(10, 2)
}

model sections {
  id                 Int       @id @default(autoincrement())
  program_id         Int
  section_name       String    @db.VarChar(100)
  advisor            String    @db.VarChar(150)
  student_count      Int?      @default(0)
  status             String    @db.VarChar(50)
  year_level         Int?
  academic_year      String?   @db.VarChar(20)
  max_capacity       Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  semester           String?   @db.VarChar(50)
  semester_temp      String?   @db.VarChar(50)
  academic_year_temp String?   @db.VarChar(20)
}

model student_section {
  id                       Int                        @id @default(autoincrement())
  student_number           String                     @db.VarChar(255)
  section_id               Int
  academic_year            String                     @db.VarChar(20)
  semester                 String?                    @db.VarChar(50)
  semester_temp            String?                    @db.VarChar(50)
  academic_year_temp       String?                    @db.VarChar(20)
  assignment_type          String?                    @default("regular") @db.VarChar(20)
  student_section_subjects student_section_subjects[]

  @@unique([student_number, academic_year, semester])
  @@index([assignment_type], map: "idx_student_section_assignment_type")
}

model student_section_subjects {
  id                 Int             @id @default(autoincrement())
  student_section_id Int
  class_schedule_id  Int
  created_at         DateTime?       @default(now()) @db.Timestamp(6)
  class_schedule     class_schedule  @relation(fields: [class_schedule_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_class_schedule")
  student_section    student_section @relation(fields: [student_section_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_student_section")

  @@unique([student_section_id, class_schedule_id], map: "unique_student_subject")
  @@index([student_section_id], map: "idx_student_section_subjects_student")
  @@index([class_schedule_id], map: "idx_student_section_subjects_schedule")
}

model class_schedule {
  id                       Int                        @id @default(autoincrement())
  section_id               Int
  curriculum_course_id     Int
  faculty_id               Int?
  room_id                  Int
  day_of_week              String                     @db.VarChar(255)
  start_time               DateTime                   @db.Timestamp(6)
  end_time                 DateTime                   @db.Timestamp(6)
  academic_year            String                     @db.VarChar(20)
  status                   String?                    @default("active") @db.VarChar(50)
  semester                 String?                    @db.VarChar(50)
  semester_temp            String?                    @db.VarChar(50)
  academic_year_temp       String?                    @db.VarChar(20)
  student_section_subjects student_section_subjects[]

  @@index([faculty_id], map: "idx_class_schedule_faculty")
  @@index([room_id], map: "idx_class_schedule_room")
  @@index([section_id, academic_year, semester], map: "idx_class_schedule_section")
}

model billing {
  id           Int       @id @default(autoincrement())
  enrollee_id  Int?
  term         String?   @db.VarChar(10)
  is_paid      Int?
  date_paid    DateTime? @db.Date
  user_id      Int?
  amount       Decimal?  @db.Decimal(10, 2)
  payment_type String?   @db.VarChar(20)
  reference_no String?   @db.VarChar(100)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model curriculum {
  id                   Int                 @id @default(autoincrement())
  program_name         String              @db.VarChar(255)
  program_code         String              @db.VarChar(100)
  major                String?             @db.VarChar(255)
  effective_year       String              @db.VarChar(20)
  total_units          Int
  status               String              @db.VarChar(10)
  tuition_fee_per_unit Decimal?            @default(570.00) @db.Decimal(10, 2)
  curriculum_course    curriculum_course[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model curriculum_course {
  id                Int        @id @default(autoincrement())
  curriculum_id     Int
  subject_id        Int?
  course_code       String     @db.VarChar(100)
  descriptive_title String
  units_lec         Int?
  units_lab         Int?
  units_total       Int
  prerequisite      String?
  year_level        Int
  semester          Int
  lecture_hour      Int?
  lab_hour          Int?
  fixedAmount       Decimal?   @db.Decimal(10, 2)
  curriculum        curriculum @relation(fields: [curriculum_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model reports {
  id         Int       @id @default(autoincrement())
  action     String    @db.VarChar(255)
  user_id    Int
  created_at DateTime? @db.Timestamp(6)
}

model settings {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.VarChar(255)
  description String?  @db.VarChar(255)
  updated_at  DateTime @default(now()) @updatedAt
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model enrolled_subjects {
  id                   Int       @id @default(autoincrement())
  student_number       String    @db.VarChar(20)
  program_id           Int?
  curriculum_course_id Int
  subject_id           Int?
  academic_year        String    @db.VarChar(20)
  semester             Int
  term                 String?   @db.VarChar(50)
  year_level           Int?
  units_total          Int       @default(0)
  status               String?   @default("enrolled") @db.VarChar(20)
  enrolled_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)

  @@index([academic_year, semester], map: "idx_enrolled_subjects_academic_term")
  @@index([program_id, semester, academic_year], map: "idx_enrolled_subjects_program_semester")
  @@index([student_number], map: "idx_enrolled_subjects_student_number")
}

model category {
  id         Int        @id @default(autoincrement())
  name       String?    @db.VarChar(10)
  created_at DateTime?  @db.Timestamp(6)
  updated_at DateTime?  @db.Timestamp(6)
  products   products[]
}

model order_details {
  id              Int       @id @default(autoincrement())
  order_header_id Int?
  product_id      Int
  quantity        Int?
  selling_price   Decimal?  @db.Decimal(10, 2)
  total           Decimal?  @db.Decimal(10, 2)
  created_at      DateTime? @db.Timestamp(6)
  updated_at      DateTime? @db.Timestamp(6)
}

model order_header {
  id               Int       @id @default(autoincrement())
  order_date       DateTime  @db.Date
  order_amount     Decimal?  @db.Decimal(10, 2)
  billing_id       Int?
  ar_number        String?   @db.VarChar(255)
  isvoided         Int?
  voided_header_id Int?
  created_at       DateTime? @db.Timestamp(6)
  updated_at       DateTime? @db.Timestamp(6)
  student_number   String?   @db.VarChar(20)
  or_number        String?   @db.VarChar(255)
  user_id          Int?
}

model payment_details {
  id              Int       @id @default(autoincrement())
  order_header_id Int?
  payment_id      Int
  amount          Decimal?  @db.Decimal(10, 2)
  tendered_amount Decimal?  @db.Decimal(10, 2)
  change_amount   Decimal?  @db.Decimal(10, 2)
  transaction_ref String?   @db.VarChar(255)
  created_at      DateTime? @db.Timestamp(6)
  updated_at      DateTime? @db.Timestamp(6)
}

model products {
  id          Int       @id @default(autoincrement())
  name        String?   @db.VarChar(100)
  category_id Int?
  created_at  DateTime? @db.Timestamp(6)
  updated_at  DateTime? @db.Timestamp(6)
  quantity    Int?
  price       Decimal?  @db.Decimal(10, 2)
  category    category? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_category_id")
}

model school {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(255)
  is_custom  Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@index([name], map: "idx_schools_name")
  @@index([is_custom], map: "idx_schools_is_custom")
  @@map("schools")
}

model shsProgram {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(255)
  is_custom  Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@index([name], map: "idx_shs_programs_name")
  @@index([is_custom], map: "idx_shs_programs_is_custom")
  @@map("shs_programs")
}

model discount {
  id          Int                  @id @default(autoincrement())
  code        String               @db.VarChar(50)
  name        String               @db.VarChar(255)
  percentage  Decimal              @db.Decimal(5, 2)
  semester    String               @db.VarChar(20)
  status      String               @db.VarChar(10)
  created_at  DateTime             @default(now()) @db.Timestamp(6)
  assessments student_assessment[]

  @@index([status, semester], map: "idx_discount_status_semester")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model student_assessment {
  id                     Int                @id @default(autoincrement())
  student_number         String             @db.VarChar(20)
  academic_year          String             @db.VarChar(20)
  semester               Int
  gross_tuition          Decimal            @db.Decimal(10, 2)
  discount_id            Int?
  discount_percent       Decimal?           @db.Decimal(5, 2)
  discount_amount        Decimal?           @db.Decimal(10, 2)
  net_tuition            Decimal            @db.Decimal(10, 2)
  total_fees             Decimal            @db.Decimal(10, 2)
  total_due              Decimal            @db.Decimal(10, 2)
  created_at             DateTime           @default(now()) @db.Timestamp(6)
  payment_mode           String             @db.VarChar(20)
  down_payment           Decimal?           @db.Decimal(10, 2)
  insurance_amount       Decimal?           @db.Decimal(10, 2)
  fixed_amount_total     Decimal?           @default(0) @db.Decimal(10, 2)
  base_total             Decimal            @db.Decimal(10, 2)
  total_due_cash         Decimal?           @db.Decimal(10, 2)
  total_due_installment  Decimal?           @db.Decimal(10, 2)
  status                 String?            @default("draft") @db.VarChar(20)
  previous_assessment_id Int?
  version                Int?               @default(1)
  updated_at             DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  finalized_at           DateTime?          @db.Timestamp(6)
  audit_logs             assessment_audit[]
  fees                   assessment_fee[]
  payment_schedules      payment_schedule[]
  discount               discount?          @relation(fields: [discount_id], references: [id], onUpdate: NoAction)
  payments               student_payment[]

  @@unique([student_number, academic_year, semester], map: "idx_assessment_unique")
  @@index([student_number], map: "idx_assessment_student")
  @@index([academic_year, semester], map: "idx_assessment_term")
  @@index([status], map: "idx_assessment_status")
}

model assessment_fee {
  id            Int                @id @default(autoincrement())
  assessment_id Int
  fee_id        Int?
  fee_name      String             @db.VarChar(255)
  fee_category  String             @db.VarChar(20)
  amount        Decimal            @db.Decimal(10, 2)
  assessment    student_assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id], map: "idx_assessment_fee_assessment")
}

model student_payment {
  id            Int                @id @default(autoincrement())
  assessment_id Int
  amount_paid   Decimal            @db.Decimal(10, 2)
  payment_type  String             @db.VarChar(50)
  payment_date  DateTime           @default(now()) @db.Timestamp(6)
  reference_no  String?            @db.VarChar(100)
  assessment    student_assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id], map: "idx_payment_assessment")
  @@index([payment_date], map: "idx_payment_date")
}

model payment_schedule {
  id            Int                @id @default(autoincrement())
  assessment_id Int
  label         String             @db.VarChar(255)
  due_date      DateTime           @db.Timestamp(6)
  amount        Decimal            @db.Decimal(10, 2)
  is_paid       Boolean            @default(false)
  assessment    student_assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_payment_schedule_assessment")

  @@index([assessment_id], map: "idx_payment_schedule_assessment")
}

model assessment_audit {
  id              Int                @id @default(autoincrement())
  assessment_id   Int
  action          String             @db.VarChar(50)
  changed_fields  String?
  previous_values String?
  new_values      String?
  user_id         Int?
  created_at      DateTime           @default(now()) @db.Timestamp(6)
  assessment      student_assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_assessment_audit_assessment")

  @@index([assessment_id], map: "idx_assessment_audit_assessment")
  @@index([action], map: "idx_assessment_audit_action")
  @@index([created_at], map: "idx_assessment_audit_created_at")
}

/// Fee category table stores titles like "Miscellaneous 2026"
model fee_category {
  id                 Int                 @id @default(autoincrement())
  title              String              @db.VarChar(255)
  description        String?
  academic_year      String              @db.VarChar(20)
  category_type      String              @default("miscellaneous") @db.VarChar(50)
  status             String              @default("active") @db.VarChar(10)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  updated_at         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  miscellaneous_fees miscellaneous_fee[]

  @@unique([academic_year, category_type], map: "uq_fee_category_year_type")
  @@index([academic_year, category_type], map: "idx_fee_category_year_type")
  @@index([status], map: "idx_fee_category_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model miscellaneous_fee {
  id          Int          @id @default(autoincrement())
  category_id Int
  item        String       @db.VarChar(255)
  amount      Decimal      @default(0.00) @db.Decimal(10, 2)
  status      String       @default("active") @db.VarChar(10)
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?    @default(now()) @updatedAt @db.Timestamp(6)
  category    fee_category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_miscellaneous_fee_category")

  @@index([category_id], map: "idx_miscellaneous_fee_category")
  @@index([status], map: "idx_miscellaneous_fee_status")
  @@map("miscellaneous_fees")
}
